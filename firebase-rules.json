{
  "rules": {
    "ogn": {
      ".read": true,
      "$compCode": {
        ".write": "auth != null && $compCode != 'admin'"
      },
      "admin": {
        ".read": true,
        ".write": false
      }
    },
    "licenses": {
      "$year": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid && (!data.exists() || data.child('status').val() === 'draft')",
          ".validate": "newData.hasChildren(['email']) && newData.child('email').isString()"
        }
      }
    },
    "athletes-profile": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
